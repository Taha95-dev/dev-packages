[
    {
        "name": "go",
        "version": "1.22",
        "windows": "https://go.dev/dl/go1.22.0.windows-amd64.msi",
        "linux": "https://go.dev/dl/go1.22.0.linux-amd64.tar.gz",
        "mac": "https://go.dev/dl/go1.22.0.darwin-amd64.pkg",
        "post_install": "go version"
    },
    {
        "name": "node",
        "version": "20",
        "windows": "https://nodejs.org/dist/v20.11.0/node-v20.11.0-x64.msi",
        "linux": "https://nodejs.org/dist/v20.11.0/node-v20.11.0-linux-x64.tar.xz",
        "mac": "https://nodejs.org/dist/v20.11.0/node-v20.11.0.pkg",
        "post_install": "node --version"
    },
    {
        "name": "git",
        "version": "2.44",
        "windows": "https://github.com/git-for-windows/git/releases/download/v2.44.0.windows.1/Git-2.44.0-64-bit.exe",
        "linux": "sudo apt install git -y",
        "mac": "brew install git",
        "post_install": "git --version"
    },
    {
        "name": "omarchy",
        "version": "latest",
        "install": "go install github.com/Taha95-dev/Omarchy-CLI-tool@latest",
        "post_install": "omarchy --version"
    },
    {
    "name": "docker",
    "version": "24",
    "description": "Containerization platform",
    "windows": "https://desktop.docker.com/win/main/amd64/Docker Desktop Installer.exe",
    "linux": "curl -fsSL https://get.docker.com | sh",
    "mac": "brew install docker",
    "post_install": "docker --version"
    }
]